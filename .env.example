# ===========================================
# Token Risk Scanner - Environment Variables
# ===========================================

# Your Base wallet address (same address works on testnet & mainnet)
# This is where you'll receive USDC payments
WALLET_ADDRESS=0xYOUR_BASE_WALLET_ADDRESS_HERE

# x402 Facilitator URL
# For testnet (free testing): https://x402.org/facilitator
# For mainnet (real payments): https://x402.org/facilitator (or CDP facilitator)
FACILITATOR_URL=https://x402.org/facilitator

# Server port
PORT=4021

# Network setting
# Testnet: eip155:84532  (Base Sepolia - use this first!)
# Mainnet: eip155:8453   (Base - switch when ready for real payments)
NETWORK=eip155:84532
